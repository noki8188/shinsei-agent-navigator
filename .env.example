# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Backend runtime
SHINSEI_WORKFLOW_BACKEND=rule_based

# LLM backend settings
SHINSEI_LLM_PROVIDER=openai
SHINSEI_LLM_MODEL=gpt-5.4-mini
SHINSEI_LLM_BASE_URL=
SHINSEI_LLM_API_KEY=
SHINSEI_LLM_TIMEOUT_SECONDS=30
SHINSEI_LLM_RETRIES=2
SHINSEI_LLM_TEMPERATURE=0
SHINSEI_LLM_MAX_OUTPUT_TOKENS=1200

# Alias supported by runtime.py
OPENAI_API_KEY=
